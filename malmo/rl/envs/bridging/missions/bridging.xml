<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>Bridging — 5-block gap</Summary>
  </About>

  <ServerSection>
    <ServerInitialConditions>
      <Time><StartTime>1000</StartTime></Time>
      <Weather>clear</Weather>
    </ServerInitialConditions>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,2*3,2;1;" forceReset="true"/>

      <DrawingDecorator>
        <!-- Clear the area above the platforms (remove default terrain) -->
        <DrawCuboid x1="-2" y1="45" z1="-1" x2="2" y2="50" z2="9" type="air"/>

        <!-- Starting platform: single block at Z=1 -->
        <DrawCuboid x1="0" y1="45" z1="1" x2="0" y2="45" z2="1" type="stone"/>

        <!-- Gap: Z=2..6 is air (5-block gap) — already air from the clear above -->

        <!-- End platform: single block at Z=7 -->
        <DrawCuboid x1="0" y1="45" z1="7" x2="0" y2="45" z2="7" type="stone"/>


      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="30000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Bridging Agent</Name>
    <AgentStart>
      <Placement x="0.5" y="46" z="1.95" yaw="180" pitch="70"/>
      <Inventory>
        <InventoryBlock slot="0" type="stone" quantity="64"/>
      </Inventory>
    </AgentStart>
    <AgentHandlers>
      <ContinuousMovementCommands/>
      <InventoryCommands/>

      <ObservationFromFullStats/>

      <ObservationFromGrid>
        <Grid name="floor3x3">
          <min x="-2" y="-2" z="-2"/>
          <max x="2"  y="2"  z="5"/>
        </Grid>
      </ObservationFromGrid>

      <ObservationFromRay/>
      <ObservationFromHotBar/>

      <AgentQuitFromTouchingBlockType>
        <Block type="gold_block"/>
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>
</Mission>
