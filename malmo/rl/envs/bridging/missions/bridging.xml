<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>Bridging — 5-block gap</Summary>
  </About>

  <ServerSection>
    <ServerInitialConditions>
      <Time><StartTime>1000</StartTime></Time>
      <Weather>clear</Weather>
    </ServerInitialConditions>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,2*3,2;1;" forceReset="true"/>

      <DrawingDecorator>
        <!-- Clear the area above the platforms (remove default terrain) -->
        <DrawCuboid x1="-3" y1="45" z1="-1" x2="3" y2="50" z2="12" type="air"/>

        <!-- Starting platform: 3-wide at Z=0..2 -->
        <DrawCuboid x1="-1" y1="45" z1="0" x2="1" y2="45" z2="2" type="stone"/>

        <!-- Gap: Z=3..7 is air (5-block gap) — already air from the clear above -->

        <!-- End platform: 3-wide at Z=8..10 -->
        <DrawCuboid x1="-1" y1="45" z1="8" x2="1" y2="45" z2="10" type="stone"/>

        <!-- Walls on sides — start above bridge level so agent can't build against them -->
        <DrawCuboid x1="-2" y1="47" z1="-1" x2="-2" y2="48" z2="11" type="stone"/>
        <DrawCuboid x1="2"  y1="47" z1="-1" x2="2"  y2="48" z2="11" type="stone"/>
      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="30000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Bridging Agent</Name>
    <AgentStart>
      <Placement x="0.5" y="46" z="1.5" yaw="0" pitch="70"/>
      <Inventory>
        <InventoryBlock slot="0" type="stone" quantity="64"/>
      </Inventory>
    </AgentStart>
    <AgentHandlers>
      <ContinuousMovementCommands/>
      <InventoryCommands/>

      <ObservationFromFullStats/>

      <ObservationFromGrid>
        <Grid name="floor3x3">
          <min x="-2" y="-2" z="-2"/>
          <max x="2"  y="2"  z="5"/>
        </Grid>
      </ObservationFromGrid>

      <ObservationFromRay/>
      <ObservationFromHotBar/>

      <AgentQuitFromTouchingBlockType>
        <Block type="gold_block"/>
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>
</Mission>
