<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<Mission xmlns="http://ProjectMalmo.microsoft.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>Multi-Jump Course - 4 jumps: 1-block, 2-block, diagonal, vertical</Summary>
  </About>

  <ServerSection>
    <ServerInitialConditions>
      <Time><StartTime>1000</StartTime></Time>
      <Weather>clear</Weather>
    </ServerInitialConditions>
    <ServerHandlers>
      <FlatWorldGenerator generatorString="3;7,2*3,2;1;" forceReset="true"/>

      <DrawingDecorator>
        <!-- Start: X=0, Y=45, Z=3 -->
        <DrawCuboid x1="0" y1="45" z1="3" x2="0" y2="45" z2="3" type="stone"/>
        <!-- Jump 1 (1-block straight): X=0, Y=45, Z=5 (gap: Z=4) -->
        <DrawCuboid x1="0" y1="45" z1="5" x2="0" y2="45" z2="5" type="stone"/>
        <!-- Jump 2 (2-block straight): X=0, Y=45, Z=8 (gap: Z=6,7) -->
        <DrawCuboid x1="0" y1="45" z1="8" x2="0" y2="45" z2="8" type="stone"/>
        <!-- Jump 3 (diagonal, 1-block gap + X+1): X=1, Y=45, Z=10 (gap: Z=9) -->
        <DrawCuboid x1="1" y1="45" z1="10" x2="1" y2="45" z2="10" type="stone"/>
        <!-- Jump 4 (vertical, 1-block gap + Y+1): X=1, Y=46, Z=12 (gap: Z=11) -->
        <DrawCuboid x1="1" y1="46" z1="12" x2="1" y2="46" z2="12" type="stone"/>
      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="20000"/>
      <ServerQuitWhenAnyAgentFinishes/>
    </ServerHandlers>
  </ServerSection>

  <AgentSection mode="Survival">
    <Name>Parkour Agent</Name>
    <AgentStart>
      <Placement x="0.5" y="46" z="3.5" yaw="0"/>
    </AgentStart>
    <AgentHandlers>
      <ContinuousMovementCommands/>
      <ObservationFromFullStats/>

      <ObservationFromGrid>
        <Grid name="floor3x3">
          <min x="-2" y="-1" z="-2"/>
          <max x="2"  y="3"  z="3"/>
        </Grid>
      </ObservationFromGrid>

      <AgentQuitFromTouchingBlockType>
          <Block type="gold_block" />
      </AgentQuitFromTouchingBlockType>
    </AgentHandlers>
  </AgentSection>
</Mission>
